# ── Supabase (required for auth) ──────────────────────────────────────────────
# Get these from: Supabase Dashboard → Project Settings → API
#
# IMPORTANT for Vercel: client-side auth needs the VITE_ prefixed vars below.
# Add ALL FOUR to Vercel → Settings → Environment Variables → Production + Preview,
# then redeploy.
SUPABASE_PROJECT_ID="fcahlgmsosbayyqmkcsu"
SUPABASE_URL="https://fcahlgmsosbayyqmkcsu.supabase.co"
SUPABASE_PUBLISHABLE_KEY="your-publishable-key"
VITE_SUPABASE_URL="https://fcahlgmsosbayyqmkcsu.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-publishable-key"
#
# Supabase Dashboard → Authentication → URL Configuration:
#   Site URL: https://founderbreif.vercel.app
#   Redirect URLs: https://founderbreif.vercel.app/auth/callback
#                  https://founderbreif.vercel.app/**
# Brevo (free: 300 emails/day) — set in Supabase Edge Function secrets
# BREVO_API_KEY=xkeysib-...
# WAITLIST_FROM_EMAIL=you@gmail.com
# WAITLIST_FROM_NAME=FounderBrief
# APP_URL=https://founderbreif.vercel.app

# Server-only (required for account deletion API)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Create at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_key_here
# Preferred name on Vercel (falls back to GEMINI_API_KEY):
APP_GEMINI_API_KEY=your_key_here

# Mobile app admin login (server-side only)
APP_ADMIN_EMAIL=bookspower218@gmail.com
APP_ADMIN_PASSWORD=your_admin_password_here
APP_JWT_SECRET=any-long-random-string
APP_URL=https://founderbreif.vercel.app

# Optional: point demo client at external API (empty = same origin)
# VITE_API_URL=https://your-api.example.com
